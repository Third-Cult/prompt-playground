# Production Environment Configuration
PORT=3002
NODE_ENV=production

# GitHub Configuration
GITHUB_WEBHOOK_SECRET=production-your-webhook-secret-here

# GitHub Authentication (RECOMMENDED - enables PR recovery)
# See AUTHENTICATION.md for complete setup guide
# Option A: Personal Access Token (not recommended for production)
# GITHUB_TOKEN=your-github-personal-access-token-here

# Option B: GitHub App (RECOMMENDED for production)
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=33333333  # Production installation ID
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYour private key here\n-----END RSA PRIVATE KEY-----"
# For production, consider using secrets manager (AWS, Azure, etc.)

# Discord Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-production-channel-id-here

# State Storage (file required for production)
STATE_STORAGE_TYPE=file
STATE_FILE_PATH=./data/pr-state.production.json

# User Mappings
USER_MAPPINGS_PATH=./config/user-mappings.json

# Logging
LOG_LEVEL=info
