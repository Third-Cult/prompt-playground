# Staging Environment Configuration
PORT=3001
NODE_ENV=staging

# GitHub Configuration
GITHUB_WEBHOOK_SECRET=staging-your-webhook-secret-here

# GitHub Authentication (Recommended - enables PR recovery)
# See AUTHENTICATION.md for setup guide
# Option A: Personal Access Token
# GITHUB_TOKEN=your-github-personal-access-token-here

# Option B: GitHub App (recommended for staging/production)
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=22222222  # Staging installation ID
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# Discord Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-staging-channel-id-here

# State Storage (file recommended for staging)
STATE_STORAGE_TYPE=file
STATE_FILE_PATH=./data/pr-state.staging.json

# User Mappings
USER_MAPPINGS_PATH=./config/user-mappings.staging.json

# Logging
LOG_LEVEL=info
