# Development Environment Configuration
PORT=3000
NODE_ENV=development

# GitHub Configuration
GITHUB_WEBHOOK_SECRET=dev-your-webhook-secret-here

# GitHub Authentication (Optional - enables PR recovery)
# See AUTHENTICATION.md for setup guide
# Option A: Personal Access Token (recommended for dev)
GITHUB_TOKEN=your-github-personal-access-token-here

# Option B: GitHub App (if testing app authentication)
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=11111111  # Dev installation ID
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# Discord Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-dev-channel-id-here

# State Storage (memory recommended for dev)
STATE_STORAGE_TYPE=memory

# User Mappings
USER_MAPPINGS_PATH=./config/user-mappings.dev.json

# Logging (debug for development)
LOG_LEVEL=debug
